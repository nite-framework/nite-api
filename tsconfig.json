{
    "include": ["src/**/*.ts", "src/test/jest.setup.ts", "../../former-utils.ts", "../../former-index.ts", "../../former-common-types.ts", "src/common-types.ts"],
    "compilerOptions": {
      "rootDir": "src",
      "outDir": "dist",
      "declaration": true,
      "lib": ["ESNext", "DOM"],  
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "node",
      "allowJs": true,
      "forceConsistentCasingInFileNames": true,
      "noImplicitAny": true,
      "strict": true,
      "isolatedModules": true,
      "sourceMap": true,
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "skipLibCheck": true
    }
  }